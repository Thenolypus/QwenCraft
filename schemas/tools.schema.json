{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://qwencraft.local/schemas/tools.schema.json",
  "title": "QwenCraftTools",
  "type": "object",
  "additionalProperties": false,
  "required": ["tools"],
  "properties": {
    "tools": {
      "type": "array",
      "items": {"$ref": "#/$defs/openaiTool"},
      "minItems": 1
    }
  },
  "$defs": {
    "openaiTool": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "function"],
      "properties": {
        "type": {"const": "function"},
        "function": {
          "type": "object",
          "additionalProperties": false,
          "required": ["name", "description", "parameters"],
          "properties": {
            "name": {"type": "string"},
            "description": {"type": "string"},
            "parameters": {"type": "object"}
          }
        }
      }
    }
  },
  "tools": [
    {
      "type": "function",
      "function": {
        "name": "goto",
        "description": "Pathfind to a block coordinate. May break/place traversable blocks and use dirt or cobble as scaffolding. Fails if no path is found.",
        "parameters": {
          "type": "object",
          "additionalProperties": false,
          "required": ["x", "y", "z"],
          "properties": {
            "x": {"type": "integer"},
            "y": {"type": "integer"},
            "z": {"type": "integer"}
          }
        }
      }
    },
    {
      "type": "function",
      "function": {
        "name": "explore",
        "description": "Walk roughly in a compass direction for a distance while avoiding obvious hazards. Fails if pathing cannot move that way.",
        "parameters": {
          "type": "object",
          "additionalProperties": false,
          "required": ["direction", "distance"],
          "properties": {
            "direction": {"type": "string", "enum": ["N", "NE", "E", "SE", "S", "SW", "W", "NW"]},
            "distance": {"type": "integer", "minimum": 1, "maximum": 128}
          }
        }
      }
    },
    {
      "type": "function",
      "function": {
        "name": "flee",
        "description": "Move away from the nearest hostile entity by approximately the requested distance. Fails if no hostile is nearby or no safe path is found.",
        "parameters": {
          "type": "object",
          "additionalProperties": false,
          "required": ["distance"],
          "properties": {
            "distance": {"type": "integer", "minimum": 4, "maximum": 64}
          }
        }
      }
    },
    {
      "type": "function",
      "function": {
        "name": "stop",
        "description": "Cancel the current tool or clear pathfinding state.",
        "parameters": {
          "type": "object",
          "additionalProperties": false,
          "properties": {}
        }
      }
    },
    {
      "type": "function",
      "function": {
        "name": "mine_block",
        "description": "Find, path to, mine, and collect nearest matching whitelisted blocks. Fails if none are in scan range or collection cannot complete.",
        "parameters": {
          "type": "object",
          "additionalProperties": false,
          "required": ["type", "count"],
          "properties": {
            "type": {"type": "string"},
            "count": {"type": "integer", "minimum": 1, "maximum": 64}
          }
        }
      }
    },
    {
      "type": "function",
      "function": {
        "name": "craft",
        "description": "Craft an item using the 2x2 grid or a nearby/placed crafting table. Missing-material failures include exact missing items.",
        "parameters": {
          "type": "object",
          "additionalProperties": false,
          "required": ["item", "count"],
          "properties": {
            "item": {"type": "string"},
            "count": {"type": "integer", "minimum": 1, "maximum": 64}
          }
        }
      }
    },
    {
      "type": "function",
      "function": {
        "name": "smelt",
        "description": "Smelt an item using a nearby/placed furnace and the best available fuel. Fails with the missing furnace, input, or fuel cause.",
        "parameters": {
          "type": "object",
          "additionalProperties": false,
          "required": ["item", "count"],
          "properties": {
            "item": {"type": "string"},
            "count": {"type": "integer", "minimum": 1, "maximum": 64}
          }
        }
      }
    },
    {
      "type": "function",
      "function": {
        "name": "obtain_item",
        "description": "Get a quantity of an item by resolving its full prerequisite chain automatically (mining, crafting, smelting, or killing as needed, including tools and intermediate materials). Prefer this over chaining mine_block/craft/smelt/attack yourself whenever the item has prerequisites. Fails informatively with what was obtained and which step blocked if the chain cannot complete.",
        "parameters": {
          "type": "object",
          "additionalProperties": false,
          "required": ["item", "count"],
          "properties": {
            "item": {"type": "string"},
            "count": {"type": "integer", "minimum": 1, "maximum": 64}
          }
        }
      }
    },
    {
      "type": "function",
      "function": {
        "name": "place_block",
        "description": "Place a named block at an exact coordinate. Fails if the block is missing, target is occupied, or no adjacent support face exists.",
        "parameters": {
          "type": "object",
          "additionalProperties": false,
          "required": ["type", "x", "y", "z"],
          "properties": {
            "type": {"type": "string"},
            "x": {"type": "integer"},
            "y": {"type": "integer"},
            "z": {"type": "integer"}
          }
        }
      }
    },
    {
      "type": "function",
      "function": {
        "name": "eat",
        "description": "Eat a named food item or the best available food. Fails if no edible item is available.",
        "parameters": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "item": {"type": "string"}
          }
        }
      }
    },
    {
      "type": "function",
      "function": {
        "name": "attack",
        "description": "Engage the nearest entity of a type with the best available weapon. Interrupts if health drops below 8.",
        "parameters": {
          "type": "object",
          "additionalProperties": false,
          "required": ["entity_type"],
          "properties": {
            "entity_type": {"type": "string"}
          }
        }
      }
    },
    {
      "type": "function",
      "function": {
        "name": "equip",
        "description": "Equip an inventory item. Armor goes to the matching armor slot; tools, weapons, and blocks go to hand.",
        "parameters": {
          "type": "object",
          "additionalProperties": false,
          "required": ["item"],
          "properties": {
            "item": {"type": "string"}
          }
        }
      }
    },
    {
      "type": "function",
      "function": {
        "name": "build_shelter",
        "description": "Build a dirt/cobble 3x3x2 shelter or dig into terrain and seal behind. Detail includes shelter position on success.",
        "parameters": {
          "type": "object",
          "additionalProperties": false,
          "required": ["style"],
          "properties": {
            "style": {"type": "string", "enum": ["dirt_box", "dig_in"]}
          }
        }
      }
    },
    {
      "type": "function",
      "function": {
        "name": "sleep",
        "description": "Sleep in a nearby bed. Fails if no bed is within 16 blocks, it is not night, or mobs are too close.",
        "parameters": {
          "type": "object",
          "additionalProperties": false,
          "properties": {}
        }
      }
    },
    {
      "type": "function",
      "function": {
        "name": "chat",
        "description": "Send an in-game chat message.",
        "parameters": {
          "type": "object",
          "additionalProperties": false,
          "required": ["message"],
          "properties": {
            "message": {"type": "string", "minLength": 1, "maxLength": 256}
          }
        }
      }
    },
    {
      "type": "function",
      "function": {
        "name": "set_goal",
        "description": "Overwrite the brain memory goal text.",
        "parameters": {
          "type": "object",
          "additionalProperties": false,
          "required": ["text"],
          "properties": {
            "text": {"type": "string", "minLength": 1, "maxLength": 300}
          }
        }
      }
    },
    {
      "type": "function",
      "function": {
        "name": "note",
        "description": "Pin a key/value memory fact. The brain keeps at most 10 keys and evicts the oldest.",
        "parameters": {
          "type": "object",
          "additionalProperties": false,
          "required": ["key", "value"],
          "properties": {
            "key": {"type": "string", "minLength": 1, "maxLength": 40},
            "value": {"type": "string", "minLength": 1, "maxLength": 300}
          }
        }
      }
    }
  ]
}
